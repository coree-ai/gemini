{
  "git": {
    "commit": true,
    "commitMessage": "chore: bump to ${version}",
    "tag": false,
    "push": true
  },
  "github": { "release": false },
  "npm": { "publish": false },
  "plugins": {
    "@release-it/bumper": {
      "out": [
        { "file": "gemini-extension.json", "path": "version" }
      ]
    }
  },
  "hooks": {
    "after:bump": "node scripts/update-npx-pin.mjs ${version}"
  }
}
