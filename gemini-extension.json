{
  "name": "coree",
  "version": "0.12.0-2",
  "description": "Persistent memory and code intelligence for AI agents",
  "mcpServers": {
    "coree": {
      "command": "npx",
      "args": [
        "--yes",
        "@coree-ai/coree@0.12.0",
        "serve"
      ],
      "env": {
        "COREE__PROJECT_ID": "$COREE__PROJECT_ID",
        "COREE__PROJECT_ROOT": "$COREE__PROJECT_ROOT",
        "COREE__MEMORY__MODE": "$COREE__MEMORY__MODE",
        "COREE__MEMORY__MANAGED_PATH": "$COREE__MEMORY__MANAGED_PATH",
        "COREE__MEMORY__LOCAL_PATH": "$COREE__MEMORY__LOCAL_PATH",
        "COREE__MEMORY__REMOTE_MODE": "$COREE__MEMORY__REMOTE_MODE",
        "COREE__MEMORY__REMOTE_URL": "$COREE__MEMORY__REMOTE_URL",
        "COREE__MEMORY__REMOTE_AUTH_TOKEN": "$COREE__MEMORY__REMOTE_AUTH_TOKEN",
        "COREE__INDEX__MODE": "$COREE__INDEX__MODE",
        "COREE__INDEX__MANAGED_PATH": "$COREE__INDEX__MANAGED_PATH",
        "COREE__INDEX__LOCAL_PATH": "$COREE__INDEX__LOCAL_PATH",
        "COREE__INDEX__REMOTE_MODE": "$COREE__INDEX__REMOTE_MODE",
        "COREE__INDEX__REMOTE_URL": "$COREE__INDEX__REMOTE_URL",
        "COREE__INDEX__REMOTE_AUTH_TOKEN": "$COREE__INDEX__REMOTE_AUTH_TOKEN",
        "COREE__INDEX__GIT_HISTORY": "$COREE__INDEX__GIT_HISTORY",
        "COREE__INDEX__EXCLUDE": "$COREE__INDEX__EXCLUDE",
        "COREE_MODEL_DIR": "$COREE_MODEL_DIR",
        "COREE_FORCE_MODEL_REFRESH": "$COREE_FORCE_MODEL_REFRESH",
        "COREE_BINARY_OVERRIDE": "$COREE_BINARY_OVERRIDE",
        "COREE_CHANNEL": "$COREE_CHANNEL",
        "RUST_LOG": "$RUST_LOG"
      },
      "description": "coree MCP server for memory and code intelligence"
    }
  },
  "contextFileName": "GEMINI.md"
}
