{
  "name": "coree",
  "version": "0.12.0-2",
  "description": "Persistent memory and code intelligence for AI agents",
  "mcpServers": {
    "coree": {
      "command": "npx",
      "args": [
        "--yes",
        "@coree-ai/coree@0.12.0",
        "serve"
      ],
      "env": {
        "COREE__MEMORY__REMOTE_AUTH_TOKEN": "${COREE__MEMORY__REMOTE_AUTH_TOKEN}",
        "COREE__INDEX__REMOTE_AUTH_TOKEN": "${COREE__INDEX__REMOTE_AUTH_TOKEN}",
        "COREE_BINARY_OVERRIDE": "${COREE_BINARY_OVERRIDE}",
        "COREE_CHANNEL": "${COREE_CHANNEL}",
        "RUST_LOG": "${RUST_LOG}"
      },
      "description": "coree MCP server for memory and code intelligence"
    }
  },
  "contextFileName": "GEMINI.md"
}
